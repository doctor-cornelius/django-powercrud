# for running tests locally and reporting coverage only on powercrud
set -euo pipefail

function show_help {
    cat <<'EOF'
Usage: ./runtests [OPTION] [TEST_PATH ...]

Options:
  --help, -h        Show this help message and exit.
  --pytest          Run only non-Playwright tests (pytest -m "not playwright").
  --playwright      Run only Playwright tests (pytest -m playwright).
  --rebuild-assets  Build static assets before running the selected tests.

Arguments:
  TEST_PATH         Run one or more pytest test paths/node ids in a single run.

Examples:
  ./runtests --playwright
  ./runtests --playwright src/tests/playwright/test_bulk_selection.py::test_bulk_selection_toggle
  ./runtests --rebuild-assets src/tests/playwright/test_bulk_selection.py::test_bulk_selection_toggle
EOF
}

MODE="all"
REBUILD_ASSETS="false"
declare -a TEST_PATHS=()

for arg in "$@"; do
    case "$arg" in
        --help|-h)
            show_help
            exit 0
            ;;
        --pytest)
            if [ "$MODE" != "all" ]; then
                show_help
                exit 1
            fi
            MODE="pytest"
            ;;
        --playwright)
            if [ "$MODE" != "all" ]; then
                show_help
                exit 1
            fi
            MODE="playwright"
            ;;
        --rebuild-assets)
            REBUILD_ASSETS="true"
            ;;
        --*)
            echo "Error: unknown option '$arg'."
            show_help
            exit 1
            ;;
        *)
            TEST_PATHS+=("$arg")
            ;;
    esac
done

function build_assets {
    echo "Building static assets..."
    npm run build
}

if [ "${#TEST_PATHS[@]}" -gt 0 ]; then
    # Explicit test-path mode: suite flags should force the normal test
    # settings, while plain path mode may still respect an explicit override.
    if [ "$MODE" != "all" ] || [ -z "${DJANGO_SETTINGS_MODULE:-}" ] || [ "${DJANGO_SETTINGS_MODULE:-}" = "config.settings" ]; then
        use_minimal_settings="false"
        use_default_settings="false"
        for test_path in "${TEST_PATHS[@]}"; do
            if [[ "$test_path" == *"minimal"* ]]; then
                use_minimal_settings="true"
            else
                use_default_settings="true"
            fi
        done

        if [ "$use_minimal_settings" = "true" ] && [ "$use_default_settings" = "true" ]; then
            echo "Error: cannot mix minimal-settings tests with regular tests in one ./runtests call."
            echo "Set DJANGO_SETTINGS_MODULE explicitly if you really want to override this safeguard."
            exit 1
        fi

        if [ "$use_minimal_settings" = "true" ]; then
            export DJANGO_SETTINGS_MODULE=tests.settings_minimal
        else
            export DJANGO_SETTINGS_MODULE=tests.settings
        fi
    fi

    if [ "$MODE" = "playwright" ] || [ "$REBUILD_ASSETS" = "true" ]; then
        build_assets
    fi

    if [ "$MODE" = "pytest" ]; then
        pytest -m "not playwright" "${TEST_PATHS[@]}"
    elif [ "$MODE" = "playwright" ]; then
        pytest -m playwright --no-cov-on-fail "${TEST_PATHS[@]}"
    else
        pytest "${TEST_PATHS[@]}"
    fi
    exit $?
fi

# delete any existing coverage reports
coverage erase
rm -rf htmlcov
rm -f coverage.xml

# All suites run under the lightweight test settings (manifest uses built files)
export DJANGO_SETTINGS_MODULE=tests.settings

if [ "$MODE" = "pytest" ]; then
    if [ "$REBUILD_ASSETS" = "true" ]; then
        build_assets
    fi
    pytest -m "not playwright"
elif [ "$MODE" = "playwright" ]; then
    build_assets
    pytest -m playwright --no-cov-on-fail
else
    # Core + async suite with coverage (skips Playwright)
    pytest -m "not playwright"

    # Ensure the built bundle exists for manifest mode
    build_assets

    # Playwright UI checks
    pytest -m playwright --cov-append --no-cov-on-fail
fi

coverage html
