#!/bin/bash
# runproj
# Calls docker compose and opens/execs into project containers.

set -euo pipefail

function show_help {
    cat <<'EOF'
Usage:
  ./runproj <action> [dev|test|prod] [args]

Actions:
  up [env]                    Start docker compose stack for env (default: dev)
  down [env]                  Stop docker compose stack for env (default: dev)
  exec [env] [command]        Enter Django container shell, or run command in it
  exec [env] --command "cmd"  Run command in Django container
  root [env]                  Enter Django container shell as root
  postgres|q2|vite|redis|pgadmin [env]
                              Enter the named service container for env

Options:
  -h, --help                  Show this help message

Examples:
  ./runproj exec
  ./runproj exec "pytest -m playwright"
  ./runproj exec test --command "pytest src/tests/playwright/test_bulk_selection.py"
  ./runproj up dev
EOF
}

ALLOWED_ENVS=("dev" "test" "prod")
ALLOWED_EXEC=("postgres" "q2" "vite" "redis" "pgadmin")
ALPINE_CONTAINERS=("redis")

ACTION="${1:-}"
if [[ -z "$ACTION" ]]; then
    echo "Error: missing action."
    show_help
    exit 1
fi
if [[ "$ACTION" == "-h" || "$ACTION" == "--help" ]]; then
    show_help
    exit 0
fi
shift

DEPLOYMENT_ENV="dev"
if [[ "${1:-}" == "dev" || "${1:-}" == "test" || "${1:-}" == "prod" ]]; then
    DEPLOYMENT_ENV="$1"
    shift
fi

EXEC_COMMAND=""
if [[ "$ACTION" == "exec" ]]; then
    if [[ "${1:-}" == "--command" ]]; then
        shift
        if [[ "$#" -eq 0 ]]; then
            echo "Error: --command requires a command string."
            show_help
            exit 1
        fi
        EXEC_COMMAND="$*"
    elif [[ "$#" -gt 0 ]]; then
        EXEC_COMMAND="$*"
    fi
elif [[ "$#" -gt 0 ]]; then
    echo "Error: unexpected arguments for action '$ACTION': $*"
    show_help
    exit 1
fi

if [[ "$ACTION" != "up" && "$ACTION" != "down" && "$ACTION" != "exec" && "$ACTION" != "root" && ! " ${ALLOWED_EXEC[*]} " =~ " ${ACTION} " ]]; then
    echo "Error: invalid action '$ACTION'."
    show_help
    exit 1
fi

echo "running runproj script to run docker-compose. ACTION=${ACTION}; DEPLOYMENT_ENV=${DEPLOYMENT_ENV}"

# pick up the required env vars
source ./docker/.env
source ./docker/${DEPLOYMENT_ENV}/${DEPLOYMENT_ENV}.secret

function exec_in {
    local exec_mode="${1:-user}"
    local command_string="${2:-}"
    local root_params=()

    if [[ "$exec_mode" == "root" ]]; then
        root_params=(-u root -w "/home/${DEPLOYMENT_ENV}user/$PROJECT_DIR")
    fi

    local container_name="${DOCKER_PREFIX}_django_${DEPLOYMENT_ENV}"
    local container_id
    container_id=$(docker ps -qf "name=${container_name}")
    echo "container_name = ${container_name}; CONTAINER = ${container_id}"

    if [[ -z "$container_id" ]]; then
        echo "Error: container '${container_name}' is not running."
        exit 1
    fi

    if [[ -n "$command_string" ]]; then
        docker exec "${root_params[@]}" "$container_id" /bin/bash -lc "$command_string"
    else
        docker exec "${root_params[@]}" -it "$container_id" /bin/bash
    fi
}

if [[ "$ACTION" == "up" ]]; then
    DEPLOYMENT_ENV=${DEPLOYMENT_ENV} \
    COMPOSE_DOCKER_CLI_BUILD=1 DOCKER_BUILDKIT=1 \
    docker compose -f ./docker/docker-compose.yml \
        --env-file ./docker/.env \
        up --detach --build
    echo "open django project after running ./src/manage.py runserver 0:8000"
    exec_in
elif [[ "$ACTION" == "down" ]]; then
    DEPLOYMENT_ENV=${DEPLOYMENT_ENV} \
    COMPOSE_DOCKER_CLI_BUILD=1 DOCKER_BUILDKIT=1 \
    docker compose -f ./docker/docker-compose.yml \
        --env-file ./docker/.env \
        down
elif [[ "$ACTION" == "exec" ]]; then
    exec_in user "$EXEC_COMMAND"
elif [[ "$ACTION" == "root" ]]; then
    exec_in root
elif [[ " ${ALLOWED_EXEC[*]} " =~ " ${ACTION} " ]]; then
    container_name="${DOCKER_PREFIX}_${ACTION}_${DEPLOYMENT_ENV}"
    CONTAINER=$(docker ps -qf "name=${container_name}")
    echo "container_name = ${container_name}; CONTAINER = ${CONTAINER}"

    if [[ $ACTION == "redis" ]]; then
        SHELL="redis-cli -a $REDIS_PASSWORD"
    elif [[ " ${ALPINE_CONTAINERS[*]} " =~ " ${ACTION} " ]]; then
        SHELL="/bin/sh"
    else
        SHELL="/bin/bash"
    fi

    docker exec -it "$CONTAINER" $SHELL
fi
